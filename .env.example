# Telegram
TELEGRAM_BOT_TOKEN=            # from @BotFather
ADMIN_TELEGRAM_ID=             # your TG user ID (optional, for reports & feedback)
VITE_TELEGRAM_BOT_USERNAME=    # bot username without @

# Cloudflare (CI secrets, not in .env)
CLOUDFLARE_ACCOUNT_ID=         # from CF dashboard
CLOUDFLARE_API_TOKEN=          # from CF dashboard

# TONAPI
TONAPI_KEY=                    # from tonconsole.com

# TON (testnet by default)
USDT_MASTER_ADDRESS=kQBqSpvo4S87mX9tjHaG4zhYZeORhVhMapBJpnMZ64jV_JBr  # testnet USDT master contract

# Frontend (Vite)
VITE_WORKER_URL=               # production worker URL (empty for dev proxy)
VITE_TG_ANALYTICS_TOKEN=       # from tganalytics.xyz (optional, injected into index.html)
VITE_TON_MANIFEST_URL=         # tonconnect-manifest.json URL (optional)

# Dev
DEV_AUTH_BYPASS_ENABLED=false  # set true for local dev without TG
ENVIRONMENT=local
